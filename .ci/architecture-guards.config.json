{
  "sharedDirectoryKinds": [
    "_lib",
    "_components",
    "_hooks",
    "_types",
    "_utils"
  ],
  "guardSeverity": {
    "duplicateBinary": "warn",
    "duplicateSemantic": "warn",
    "overCommonization": "warn",
    "relativeCrossSection": "warn",
    "aliasImportForbidden": "warn"
  },
  "guardThresholds": {
    "duplicateBinaryMinFiles": 3,
    "duplicateSemanticMinFiles": 3,
    "semanticDuplicateMinNormalizedChars": 120,
    "overCommonizationMinCrossSectionRefs": 3,
    "overCommonizationMinSectionsToEnforce": 2,
    "maxAnnotationFilesPerViolation": 20
  },
  "allowedFailedIds": [],
  "allowedAliasImports": {
    "exact": [
      "@/lib/prisma",
      "@/lib/auth",
      "@/lib/log",
      "@/lib/utils"
    ],
    "prefixes": [
      "@/components/ui/"
    ]
  },
  "aliasResolutionOverrides": {
    "@/protected/": "app/(protected)/"
  }
}
